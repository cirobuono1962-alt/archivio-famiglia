rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getRuolo() {
      return get(/databases/$(database)/documents/utenti/$(request.auth.uid)).data.ruolo;
    }

    function getCategorieVisibili() {
      return get(/databases/$(database)/documents/utenti/$(request.auth.uid)).data.categorieVisibili;
    }

    match /documenti/{docId} {
      // admin, familiare, lettore vedono tutto; esterno solo le sue categorie
      allow read: if isSignedIn() && (
        getRuolo() in ["admin", "familiare", "lettore"] ||
        (getRuolo() == "esterno" && resource.data.categoria in getCategorieVisibili())
      );
      // solo admin e familiare possono scrivere (lettore ed esterno sono sola lettura)
      allow create, update: if isSignedIn() && getRuolo() in ["admin", "familiare"];
      allow delete: if isSignedIn() && getRuolo() in ["admin", "familiare"];
    }

    match /utenti/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /categorie/{catId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && getRuolo() in ["admin", "familiare"];
      allow delete: if isSignedIn() && getRuolo() == "admin";
    }
 
    match /appuntamenti/{appId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && getRuolo() in ["admin", "familiare"];
      allow delete: if isSignedIn() && getRuolo() in ["admin", "familiare"];
    }
  }
}
